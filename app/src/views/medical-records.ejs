<!DOCTYPE html>
<html>
<head>

<title>Medical Records</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-5">

<h1>Medical Records</h1>

<table class="table">

<tr>

<th>ID</th>

<th>Patient</th>

<th>Doctor</th>

<th>Diagnosis</th>

<th>Prescription</th>

<th>Date</th>

</tr>

<% records.forEach(r=>{ %>

<tr>

<td><%= r.id %></td>

<td><%= r.patient_id %></td>

<td><%= r.doctor_id %></td>

<td><%= r.diagnosis %></td>

<td><%= r.prescription %></td>

<td><%= r.visit_date %></td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>