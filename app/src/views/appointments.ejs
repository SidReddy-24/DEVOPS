<!DOCTYPE html>
<html>
<head>

<title>Appointments</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-5">

<h1>Appointments</h1>

<table class="table">

<tr>

<th>ID</th>

<th>Patient</th>

<th>Doctor</th>

<th>Date</th>

<th>Status</th>

</tr>

<% appointments.forEach(a=>{ %>

<tr>

<td><%= a.id %></td>

<td><%= a.patient_id %></td>

<td><%= a.doctor_id %></td>

<td><%= a.appointment_date %></td>

<td><%= a.status %></td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>
