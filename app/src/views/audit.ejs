<!DOCTYPE html>
<html>
<head>
<title>Audit Logs</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container mt-5">

<h1>Audit Logs</h1>

<table class="table">

<tr>

<th>ID</th>

<th>User</th>

<th>Action</th>

<th>Time</th>

</tr>

<% logs.forEach(log=>{ %>

<tr>

<td><%= log.id %></td>

<td><%= log.user_id %></td>

<td><%= log.action %></td>

<td><%= log.created_at %></td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>